# Copy to `.env` and fill in. Never commit `.env`.

# === Shared ====================================================================
# Random key clients (Coder Agents) must present to reach the sidecars. Set this
# to any sufficiently random string and paste the same value into Coder Agents'
# admin UI as the API key for each provider. Headroom forwards it untouched.
#   openssl rand -hex 32
SIDECAR_SHARED_API_KEY=

# === claude-sidecar ============================================================
# Long-lived Claude Code OAuth token. Generate on a host with `claude` installed:
#   claude setup-token
# (Sidecar README documents the volume-mount alternative if you prefer 8h refresh
# cycles over ~1-year token rotation.)
CLAUDE_CODE_OAUTH_TOKEN=

# Optional pins
MERIDIAN_VERSION=latest
CLAUDE_CODE_VERSION=latest

# === codex-sidecar =============================================================
# Path on the host containing Codex CLI auth files. Bootstrap with `codex login`
# on the host first. Defaults to a local directory under this stack so first-run
# doesn't blow up; populate it before starting the codex-sidecar service.
CODEX_HOME=./codex-sidecar/auth

# Optional pin
CODEX_BRIDGE_REF=main

# === gemini-sidecar ============================================================
# Path on the host containing Gemini CLI OAuth files written by:
#   docker run --rm -it -v "$PWD/gemini-sidecar/auth:/data/auth" \
#     eceasy/cli-proxy-api:latest --auth-dir /data/auth --login gemini
GEMINI_SIDECAR_AUTH_DIR=./gemini-sidecar/auth

# === headroom ==================================================================
# Public port Coder Agents talks to. If coderd runs on the same host, leave at
# 8787 and use http://localhost:8787 in admin config; if remote, expose via
# whatever ingress fronts your Coder deployment.
HEADROOM_PUBLIC_PORT=8787
HEADROOM_MODE=token
HEADROOM_TELEMETRY=off
HEADROOM_IMAGE=ghcr.io/chopratejas/headroom:latest

# === Image overrides (rarely needed) ===========================================
CLI_PROXY_IMAGE=eceasy/cli-proxy-api:latest
