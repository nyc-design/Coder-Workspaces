#!/usr/bin/env python3
"""mcp-wrap — run a command with PR_SET_PDEATHSIG so it dies when its parent exits.

Usage: mcp-wrap <command> [args...]

When the direct parent process (Claude / HAPI) terminates, the kernel
automatically delivers SIGTERM to this process AND the exec'd child,
preventing orphaned MCP servers from accumulating.

Works on Linux only (uses prctl(2)).  On other platforms falls through
to a plain exec.
"""
import os
import signal
import sys

def set_pdeathsig():
    """Ask the kernel to send us SIGTERM when our parent dies."""
    try:
        import ctypes
        import ctypes.util
        PR_SET_PDEATHSIG = 1
        libc = ctypes.CDLL(ctypes.util.find_library("c"), use_errno=True)
        rc = libc.prctl(PR_SET_PDEATHSIG, signal.SIGTERM, 0, 0, 0)
        if rc != 0:
            print(f"[mcp-wrap] prctl failed (rc={rc})", file=sys.stderr)
    except Exception as e:
        print(f"[mcp-wrap] PR_SET_PDEATHSIG unavailable: {e}", file=sys.stderr)

def main():
    if len(sys.argv) < 2:
        print("Usage: mcp-wrap <command> [args...]", file=sys.stderr)
        sys.exit(1)

    set_pdeathsig()

    # If parent already died between spawn and prctl, getppid() == 1
    if os.getppid() == 1:
        sys.exit(0)

    # Replace this process with the real MCP server
    cmd = sys.argv[1:]
    os.execvp(cmd[0], cmd)

if __name__ == "__main__":
    main()
