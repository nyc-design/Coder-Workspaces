#!/usr/bin/env bash
# compute-extension-disable-list
#
# Emit (one ID per line, stdout) the extension IDs present in the shared
# extension cache but NOT in any active manifest. The launcher scripts
# (code-server-launch.sh, vscode-web-launch.sh) consume this list and
# pass --disable-extension <id> for each ID, so the editor sees only the
# union of the active manifests as enabled.
#
# Active manifests considered:
#   - Tier 1 (global)  : /usr/local/share/workspace-extensions.d/*.json
#   - Tier 2 (image)   : same dir; child images drop their own *.json there
#   - Tier 3 (project) : each /workspaces/<project>/.devcontainer/devcontainer.json
#                        and /workspaces/<project>/.vscode/extensions.json
#
# All sources are read fresh at launch — no provenance ledger. The shared
# cache stays the single source of truth on disk; this script just decides
# which of its contents are activated for the current workspace.
#
# Env vars (with defaults):
#   EXTENSIONS_DIR   /home/coder/.vscode-extensions/shared
#   MANIFEST_DIR     /usr/local/share/workspace-extensions.d
#   WORKSPACES_ROOT  /workspaces
#
# Fail-open: any error path that prevents us from computing the manifest
# set produces empty output, which means no disables — better to leak a
# few extensions than to disable everything.

set -euo pipefail

EXTENSIONS_DIR="${EXTENSIONS_DIR:-/home/coder/.vscode-extensions/shared}"
MANIFEST_DIR="${MANIFEST_DIR:-/usr/local/share/workspace-extensions.d}"
WORKSPACES_ROOT="${WORKSPACES_ROOT:-/workspaces}"

[[ -d "$EXTENSIONS_DIR" ]] || exit 0

declare -A manifest_set

# Tier 1 + Tier 2 manifests in MANIFEST_DIR.
if [[ -d "$MANIFEST_DIR" ]] && command -v jq >/dev/null 2>&1; then
  shopt -s nullglob
  for manifest in "$MANIFEST_DIR"/*.json; do
    while IFS= read -r ext; do
      [[ -z "$ext" ]] && continue
      manifest_set["${ext,,}"]=1
    done < <(jq -r '((.shared // []) + (.vscode_web_only // []))[]' "$manifest")
  done
fi

# Tier 3 project manifests — parse JSONC via node (same helper shape as
# 28-project-extensions.sh; keeping the two in sync is intentional).
if [[ -d "$WORKSPACES_ROOT" ]] && command -v node >/dev/null 2>&1; then
  shopt -s nullglob
  for project in "$WORKSPACES_ROOT"/*/; do
    project="${project%/}"
    name="$(basename "$project")"
    case "$name" in .*) continue ;; esac

    for manifest in "$project/.devcontainer/devcontainer.json" "$project/.vscode/extensions.json"; do
      [[ -f "$manifest" ]] || continue
      while IFS= read -r ext; do
        [[ -z "$ext" ]] && continue
        manifest_set["${ext,,}"]=1
      done < <(FILE="$manifest" node <<'NODE'
const fs = require('fs');
const path = require('path');
const file = process.env.FILE;
let text;
try { text = fs.readFileSync(file, 'utf8'); } catch (e) { process.exit(0); }
text = text
  .replace(/\/\*[\s\S]*?\*\//g, '')
  .replace(/^([^"\n]*?)\/\/.*$/gm, '$1')
  .replace(/,(\s*[}\]])/g, '$1');
let data;
try { data = JSON.parse(text); } catch (e) { process.exit(0); }
const base = path.basename(file);
let ids = [];
if (base === 'devcontainer.json') {
  ids = data?.customizations?.vscode?.extensions ?? [];
} else if (base === 'extensions.json') {
  ids = data?.recommendations ?? [];
}
for (const id of ids) {
  if (typeof id === 'string' && id.trim()) {
    process.stdout.write(id.trim() + '\n');
  }
}
NODE
)
    done
  done
fi

# Fail-open: if we couldn't collect any manifest entries, emit nothing
# rather than disabling every cached extension.
if [[ ${#manifest_set[@]} -eq 0 ]]; then
  exit 0
fi

# Walk the cache and emit any installed extension not in the manifest set.
# Extension dirs follow the VS Code convention "<publisher>.<name>-<version>"
# where <version> begins with a digit; strip the trailing "-<version>" to
# recover the ID.
shopt -s nullglob
for entry in "$EXTENSIONS_DIR"/*/; do
  basename="$(basename "${entry%/}")"
  id="$(printf '%s' "$basename" | sed -E 's/-[0-9][0-9A-Za-z.+-]*$//')"
  [[ -z "$id" || "$id" == "$basename" ]] && continue
  if [[ -z "${manifest_set[${id,,}]:-}" ]]; then
    printf '%s\n' "$id"
  fi
done
