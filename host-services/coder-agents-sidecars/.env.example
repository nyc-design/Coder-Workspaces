# Required env vars for the coder-agents-sidecars container.
# Copy the relevant line into the same `.env` your host docker-compose reads.
#
# Everything else — SIDECAR_SHARED_API_KEY, CLAUDE_CODE_OAUTH_TOKEN, GROQ_API_KEY,
# CEREBRAS_API_KEY, CODESTRAL_API_KEY, ZEN_API_KEY — lives in GCP Secret Manager
# (project: ai-sidecar-nt) and is fetched at container start by the
# bootstrap-secrets oneshot. Rotating any of those is a `gcloud secrets versions
# add ...` followed by a container restart — no .env edit needed.

# Single-line service-account JSON for the sidecar-runtime SA. Must have
# roles/secretmanager.secretAccessor on projects/ai-sidecar-nt. Accepted
# formats: raw JSON (single-quoted, no newlines) or base64-encoded JSON.
#
#   gcloud iam service-accounts keys create /tmp/sa.json \
#     --iam-account=sidecar-runtime@ai-sidecar-nt.iam.gserviceaccount.com
#   echo "GOOGLE_APPLICATION_CREDENTIALS_JSON='$(jq -c . /tmp/sa.json)'" >> .env
#   shred -u /tmp/sa.json
GOOGLE_APPLICATION_CREDENTIALS_JSON=
