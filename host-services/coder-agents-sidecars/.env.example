# Required env vars for the coder-agents-sidecars container.
# Copy the relevant lines into the same `.env` your host docker-compose reads.

# Random key Coder Agents sends and Headroom forwards untouched to each sidecar.
# Same value goes in Coder admin's API-key field for Anthropic + OpenAI + Google.
#   openssl rand -hex 32
SIDECAR_SHARED_API_KEY=

# Long-lived Claude Code OAuth token (token-only auth path; default in this image).
# Generate on a host with claude CLI installed and logged in:
#   claude setup-token
# Alternative: leave this blank, then `docker exec -it coder-agents-sidecars claude
# login` after first start to use the credentials-dir flow with 8h refresh cycles.
CLAUDE_CODE_OAUTH_TOKEN=
